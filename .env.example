# App Configuration
APP_NAME=WebGIS Drainase Brebes
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# Frontend
VITE_API_URL=http://localhost:8000/api
VITE_APP_NAME=WebGIS Drainase

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=webgis_drainase
DB_USERNAME=webgis_user
DB_PASSWORD=webgis_secure_password

# Redis (optional)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@webgis-drainase.com
MAIL_FROM_NAME="WebGIS Drainase Brebes"

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINTS=false

# JWT
JWT_SECRET=your-secret-key

# Map Configuration
MAP_DEFAULT_CENTER_LAT=-7.2575
MAP_DEFAULT_CENTER_LNG=108.7392
MAP_DEFAULT_ZOOM=10

# Pagination
PERFORMANCE_PAGE_SIZE=50
